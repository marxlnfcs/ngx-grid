{
  "name": "@marxlnfcs/ngx-grid",
  "description": "Angular library to create a simple grid layout",
  "version": "3.1.1",
  "license": "GPL-3.0",
  "author": "marxlnfcs",
  "homepage": "https://github.com/marxlnfcs/ngx-grid#readme",
  "bugs": {
    "url": "https://github.com/marxlnfcs/ngx-grid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marxlnfcs/ngx-grid.git"
  },
  "keywords": [
    "angular",
    "grid"
  ],
  "scripts": {
    "barrelsby": "barrelsby --config barrelsby.config.json",
    "start": "ng serve ngx-grid-view --port 4201",
    "build": "npm run barrelsby && ng build ngx-grid",
    "npm-publish": "npm run build && cd dist/ngx-grid && npm publish --access public"
  },
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "rxjs": "^7.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "~22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@types/jasmine": "~4.0.0",
    "barrelsby": "^2.8.1",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~4.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
